# Backend environment. Copy to backend/.env. All keys are optional except where noted.
# Field names map to app/config.py Settings (case-insensitive).

# ── Database ────────────────────────────────────────────────────────────
# Async SQLAlchemy URL. Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite+aiosqlite:///./portai.db

# ── Market data provider ────────────────────────────────────────────────
PROVIDER_MAX_CONCURRENCY=5
PROVIDER_JITTER_SECONDS=0.05
DEFAULT_MARKET=NSE

# ── LLM (Phase 3+). Pipeline runs without a key (memo is skipped). ──────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# ── Fund (Phase 4+) ─────────────────────────────────────────────────────
BASE_CURRENCY=INR

# ── Notifications (Phase 4+) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
