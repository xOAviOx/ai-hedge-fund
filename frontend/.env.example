# Frontend environment (Next.js). Copy to .env.local for local dev.
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time.

# Backend API origin (used directly by the browser, incl. SSE streams).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase auth (optional — auth is disabled if unset; the app still builds/runs).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
