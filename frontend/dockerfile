FROM node:18-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY . .

# NEXT_PUBLIC_* vars are inlined at build time, so the API origin must be a
# build arg (not just a runtime env). Compose passes it from NEXT_PUBLIC_API_URL.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
