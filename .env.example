# Root env for `docker compose`. Copy to `.env` and fill what you need — every
# value is optional. The pipeline runs without an LLM key (the memo is skipped)
# and without Telegram (no push). See backend/.env.example for the full backend
# surface and frontend/.env.example for the frontend.

# ── LLM (any one key enables the daily memo; provider set by LLM_PROVIDER) ──
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Telegram memo push (both required to enable) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Frontend → backend origin (inlined into the client bundle at build time) ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend database (compose defaults to the persisted volume path) ──
# DATABASE_URL=sqlite+aiosqlite:////data/portai.db
